{
  "entities": {
    "student": {
      "title": "Alumno",
      "description": "Información del estudiante inscrito.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "lastName": { "type": "string" },
        "curp": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "parentEmail": { "type": "string", "format": "email", "description": "Email del padre para acceso al portal" },
        "grade": { "type": "string" },
        "group": { "type": "string" },
        "rfc": { "type": "string", "description": "RFC para facturación" },
        "billingName": { "type": "string", "description": "Nombre o razón social para facturación" },
        "billingAddress": { "type": "string" },
        "zipCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "lastName", "grade"]
    },
    "payment": {
      "title": "Pago",
      "description": "Registro de pago de colegiatura u otros conceptos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "concept": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["Efectivo", "Transferencia", "Tarjeta", "Cheque"] },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pagado", "Pendiente", "Cancelado"] },
        "invoiceId": { "type": "string", "description": "ID de la factura en Facturapi" },
        "invoiceUrl": { "type": "string", "description": "URL del PDF de la factura" },
        "facturapiStatus": { "type": "string" }
      },
      "required": ["studentId", "amount", "concept", "paymentMethod", "date"]
    },
    "expense": {
      "title": "Gasto",
      "description": "Registro de gastos operativos de la escuela.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pagado", "Pendiente"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "category", "date", "status"]
    },
    "settings": {
      "title": "Configuración",
      "description": "Ajustes del sistema, Facturapi y datos de la escuela.",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "legalName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "facturapiApiKey": { "type": "string" },
        "facturapiSandbox": { "type": "boolean" },
        "paymentMethods": { "type": "array", "items": { "type": "string" } }
      }
    },
    "appUser": {
      "title": "Usuario del Sistema",
      "description": "Personal administrativo o padres con acceso al sistema.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Superadministrador", "Administrador", "Visor", "Cajero", "Padre"] },
        "permissions": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role", "permissions"]
    },
    "announcement": {
      "title": "Aviso",
      "description": "Comunicados oficiales para los padres.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "important"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "content", "type", "active"]
    },
    "enrollment": {
      "title": "Solicitud de Inscripción",
      "description": "Formulario de inscripción completado por padres.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "folio": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendiente", "Aprobado", "Rechazado"] },
        "studentName": { "type": "string" },
        "studentLastName": { "type": "string" },
        "curp": { "type": "string" },
        "grade": { "type": "string" },
        "level": { "type": "string" },
        "fatherEmail": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "student",
      "description": "Colección de alumnos."
    },
    "/payments/{paymentId}": {
      "schema": "payment",
      "description": "Colección de pagos realizados."
    },
    "/expenses/{expenseId}": {
      "schema": "expense",
      "description": "Colección de gastos operativos."
    },
    "/settings/general": {
      "schema": "settings",
      "description": "Documento único de configuración."
    },
    "/users/{userId}": {
      "schema": "appUser",
      "description": "Colección de usuarios administrativos y padres."
    },
    "/announcements/{announcementId}": {
      "schema": "announcement",
      "description": "Colección de avisos para padres."
    },
    "/enrollments/{enrollmentId}": {
      "schema": "enrollment",
      "description": "Colección de solicitudes de inscripción."
    }
  }
}
