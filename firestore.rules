// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: students
// Document ID: auto-generated
// Fields:
//   - name: string (required)
//   - lastName: string (required)
//   - level: string (required)
//   - grade: string (required)
//   - group: string
//   - createdAt: timestamp
//
// Collection: payments
// Document ID: auto-generated
// Fields:
//   - studentId: string (required)
//   - amount: number (required)
//   - concept: string (required)
//   - date: timestamp (required)
//   - status: string
//
// Collection: settings
// Document ID: general
// Fields:
//   - schoolName: string
//   - facturapiApiKey: string
//
// Collection: cycles
// Document ID: auto-generated
// Fields:
//   - name: string
//   - tuitionAmount: number
//
// Collection: users
// Document ID: userId (auth.uid)
// Fields:
//   - email: string
//   - name: string
//   - role: string (Superadministrador, Administrador, Visor, Cajero)
//   - permissions: map
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "cramonmb@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Superadministrador');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isParent() {
      return isAuthenticated() && getUserData().role == 'Padre';
    }

    function hasPermission(section, action) {
      return isSuperAdmin() || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              getUserData().permissions[section][action] == true);
    }

    function isChildOfParent(studentId) {
      let student = get(/databases/$(database)/documents/students/$(studentId)).data;
      return student.parentEmail == request.auth.token.email;
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated() && (hasPermission('students', 'view') || resource.data.parentEmail == request.auth.token.email);
      allow create: if isAuthenticated() && hasPermission('students', 'create');
      allow update: if isAuthenticated() && (
        hasPermission('students', 'edit') || 
        (resource.data.parentEmail == request.auth.token.email && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rfc', 'billingName', 'billingAddress', 'zipCode', 'taxSystem']))
      );
      allow delete: if isAuthenticated() && hasPermission('students', 'delete');
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (hasPermission('payments', 'view') || (isParent() && isChildOfParent(resource.data.studentId)));
      allow create: if isAuthenticated() && hasPermission('payments', 'create');
      allow update: if isAuthenticated() && (
        hasPermission('payments', 'cancel') || 
        (isParent() && isChildOfParent(resource.data.studentId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['conektaOrderId', 'status', 'paymentMethod', 'updatedAt']))
      );
      allow delete: if false; // No physical deletes for payments
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && hasPermission('expenses', 'view');
      allow create: if isAuthenticated() && hasPermission('expenses', 'create');
      allow update: if isAuthenticated() && hasPermission('expenses', 'edit');
      allow delete: if isAuthenticated() && hasPermission('expenses', 'delete');
    }

    // Settings
    match /settings/{docId} {
      allow read: if true; // Allow public read for backend proxy (API keys)
      allow write: if isAuthenticated() && isSuperAdmin();
    }

    // Cycles
    match /cycles/{cycleId} {
      allow read: if isAuthenticated() && hasPermission('settings', 'view');
      allow write: if isAuthenticated() && hasPermission('settings', 'editCycles');
    }

    // Users (for role management)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasPermission('settings', 'manageUsers'));
      allow create: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin() && request.auth.uid != userId;
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isSuperAdmin() || hasPermission('settings', 'editGeneral'));
    }

    // Enrollments
    match /enrollments/{enrollmentId} {
      allow create: if true; // Public enrollment form
      allow read: if isAuthenticated() && hasPermission('controlEscolar', 'view');
      allow update: if isAuthenticated() && hasPermission('controlEscolar', 'manage');
      allow delete: if isAuthenticated() && isSuperAdmin();
    }
  }
}
